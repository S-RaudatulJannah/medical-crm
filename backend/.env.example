# Medical CRM — Environment Variables
# Salin file ini menjadi .env dan isi dengan nilai asli kamu
# JANGAN commit file .env ke Git!

# ── Supabase ──────────────────────────────────────────────
# Dapat ditemukan di: Supabase Dashboard → Project Settings → API

# Project URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Gunakan service_role key (bukan anon key) agar backend bisa bypass RLS
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App ───────────────────────────────────────────────────
APP_ENV=development
